{
  "dashboard": {
    "title": "Spring Boot Application Monitoring",
    "tags": ["spring-boot", "jvm", "metrics"],
    "timezone": "browser",
    "templating": {
      "list": [
        {
          "name": "env",
          "label": "Environment",
          "type": "custom",
          "query": "prod,stg,dev",
          "current": {
            "text": "stg",
            "value": "stg"
          },
          "options": [
            {
              "selected": false,
              "text": "prod",
              "value": "prod"
            },
            {
              "selected": true,
              "text": "stg",
              "value": "stg"
            },
            {
              "selected": false,
              "text": "dev",
              "value": "dev"
            }
          ]
        }
      ]
    },
    "panels": [
      {
        "title": "JVM Memory Used",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "sum(jvm_memory_used_bytes{job=\"spring-boot-app\", environment=~\"$env\"})",
            "legendFormat": "Used Memory"
          }
        ]
      },
      {
        "title": "CPU Usage",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "system_cpu_usage{job=\"spring-boot-app\", environment=~\"$env\"}",
            "legendFormat": "CPU Usage"
          }
        ]
      },
      {
        "title": "HTTP Requests Rate",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "rate(http_server_requests_seconds_count{job=\"spring-boot-app\", environment=~\"$env\"}[5m])",
            "legendFormat": "{{uri}} - {{method}}"
          }
        ]
      },
      {
        "title": "Database Connection Pool",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "hikaricp_connections_active{job=\"spring-boot-app\", environment=~\"$env\"}",
            "legendFormat": "Active Connections"
          }
        ]
      }
    ]
  }
}
