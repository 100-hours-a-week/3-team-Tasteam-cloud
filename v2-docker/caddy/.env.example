# Select which site file to import: sites/dev.caddy or sites/prod.caddy
ENVIRONMENT=dev

# Caddy admin API must stay reachable from the alloy container for metrics scraping.
CADDY_ADMIN=0.0.0.0:2019

# Reverse proxy upstreams
SPRING_UPSTREAM=10.13.139.255:8080

# Load-test toggles
ENCODE_PROFILE=gzip_zstd
ACCESS_LOG_PROFILE=on
RATE_LIMIT_PROFILE=on

# Reverse proxy tuning
UPSTREAM_MAX_CONNS=200
UPSTREAM_WS_MAX_CONNS=1000
UPSTREAM_DIAL_TIMEOUT=3s
UPSTREAM_RESPONSE_HEADER_TIMEOUT=10s
UPSTREAM_READ_TIMEOUT=30s

# Static frontend root inside the caddy container
STATIC_ROOT=/var/www/html/current

# Basic auth hashes
SWAGGER_ADMIN_HASH='$2a$12$TrifdxmIojTpk7LrWun67.Jxv.PhUOieVEnceADxKDRfURMTILyxq'

# Alloy remote endpoints
LOKI_HOST=
PROMETHEUS_HOST=
HOSTNAME=
